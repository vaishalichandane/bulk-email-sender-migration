{
  "name": "bulk-email-sender",
  "version": "2.0.0",
  "type": "module",
  "description": "Web-based bulk email sender with user management and WYSIWYG editor",
  "main": "src/app.ts",
  "scripts": {
    "dev": "tsx watch --experimental-sqlite src/app.ts",
    "build": "tsc",
    "start": "tsx --experimental-sqlite src/app.ts",
    "clean": "rm -rf dist uploads/* logs/* data/users.db",
    "reset-db": "rm -f data/users.db data/scheduler.db",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "email",
    "bulk-email",
    "smtp",
    "nodemailer",
    "typescript",
    "authentication",
    "user-management"
  ],
  "author": "Vaishali Chandane",
  "license": "MIT",
  "dependencies": {
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0",
    "nodemailer": "^6.9.8",
    "xlsx": "^0.18.5",
    "multer": "^1.4.5-lts.1",
    "csv-stringify": "^6.4.4",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.14",
    "@types/multer": "^1.4.11",
    "typescript": "^5.3.3",
    "tsx": "^4.19.0",
    "@types/bcryptjs": "^2.4.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}